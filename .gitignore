# ====================================
# UPEX Project Starter - .gitignore
# ====================================

# Dependencies
node_modules/

# ===== SDD / Framework Caches =====
# .atl/ holds sdd-init generated registry, regenerated on demand
.atl/
# Known underscore-prefixed caches. Listed explicitly because a blanket
# `*_*/` rule would also swallow skill subfolders like
# `.claude/skills/<skill>/references/_shared/`, which we DO want to commit
# (this repo is a boilerplate — skills must ship).
.husky/_/

# ===== Build Artifacts =====
dist/
build/
.next/
**/out/
*.tsbuildinfo
next-env.d.ts

# ===== Playwright Test Artifacts =====
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# ===== Auth Storage (Session State) =====
/.auth/

# ===== Allure Reports =====
/allure-results/
/allure-report/

# ===== Custom Reports =====
/reports/
*.json.bak

# ===== Debug Logs =====
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===== Environment =====
.env
.env.local
.env.*.local
.env.sentry-build-plugin
.envrc.local
.direnv/
# Force-track .envrc (overrides global gitignore, which often blanket-ignores it)
!.envrc

# ===== IDE & Editor =====
.idea/
.windsurf/
.cursor/
*.swp
*.swo
*.code-workspace

# ===== OS Files =====
.DS_Store
Thumbs.db

# ===== Vercel =====
.vercel

# ===== AI CLI Tools & Configs =====
.serena
.gemini/
.claude/settings.local.json
# Claude Code scheduler runtime lock (sessionId + pid) — written by
# ScheduleWakeup / scheduled tasks. Per-session, never committed.
.claude/scheduled_tasks.lock
.playwright-mcp
.backups/

# ===== MCP Configuration =====
# .mcp.json and opencode.jsonc are COMMITTED — they reference secrets via
# ${VAR} / {env:VAR} expansion. Real values live in .env (ignored above).
# Local per-developer overrides go in *.local.* files (ignored below).
.mcp.local.json
opencode.local.jsonc
# dbhub.toml is COMMITTED (committed; ${VAR} placeholders, no secrets) — part of                                                           
# the QA testing-MCP strategy, same convention as .mcp.json / opencode.jsonc above.                                                        
# Per-developer overrides go in dbhub.local.toml (ignored below).                                                                          
dbhub.local.toml 

# Planning / audit scaffolding (working notes, plan drafts, audit
# reports, session handoffs). Kept on local disk only — never pushed.
.scratch/

# Session-management state for long workflow skills (per
# .claude/skills/agentic-dev-core/references/session-management.md).
# Contains per-skill plan.md / progress.md and archived sessions.
# Local-only — canonical artifacts are committed under .context/.
.session/

# ===== Installer lock + state =====
# `.template/installer.lock.json` is TRACKED (small, immutable sentinel that
# pins the bootstrapped template — written once by the scaffolder / installer).
# `.template/installer.state.json` is GITIGNORED (per-dev runtime idempotency
# cache — tracks which `bun setup` steps already completed).
# `.template/claude-md.upstream.sha` is GITIGNORED (per-dev runtime marker —
# records the last upstream CLAUDE.md the updater advised about, so the merge
# nudge fires once per upstream change, not every `bun up`).
.template/installer.state.json
.template/claude-md.upstream.sha

# ===== Refcheck local config (per-dev tuning, not committed) =====
.refcheckrc.toml

# ===== Skill-creator eval workspaces (local iteration artifacts, never committed) =====
.claude/skills/*-workspace/

# ===== Force-track skills lockfile =====
# skills.lock.json is generated by `bunx skills add` in scaffolded projects to
# pin the exact community-skill versions installed. It MUST be committed so
# teams reproduce the same skill set. Defensive entry — nothing above currently
# matches it, but this guards against future blanket *.lock or skills.* rules.
!skills.lock.json
!**/skills.lock.json
