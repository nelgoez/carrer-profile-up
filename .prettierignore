# ===========================================
# TypeScript/JavaScript - ESLint handles these
# ===========================================
*.ts
*.tsx
*.js
*.jsx

# ===========================================
# Documentation - Preserve manual formatting
# ===========================================
.context/
.prompts/
.books/

# ===========================================
# Skill directories - never format
# ===========================================
# Skills (T1 in .claude/skills/, T3/T4 community in .agents/skills/) ship as-is.
# Prettier must NOT touch their .md / .json / .yaml — frontmatter, fenced code,
# and example blocks rely on exact whitespace that Prettier would normalize.
.claude/skills/
.agents/skills/
# Per-developer local Claude Code settings — gitignored, harness-written. Prettier
# honors only .prettierignore (not .gitignore), so without this it scans the local
# file. Exact path, NOT `.claude/*.json` — that would swallow the tracked official
# `.claude/settings.json`, which must stay formatted.
.claude/settings.local.json

# ===========================================
# MCP reference templates - never format
# ===========================================
# docs/mcp/*.template.* are syntax-sensitive opt-in configs (claude / opencode /
# gemini / codex) that users copy verbatim into their active MCP config. Prettier
# normalizes whitespace and trailing commas that would break the copy-paste path.
docs/mcp/

# ===========================================
# Installer state - regenerated by bun run setup
# ===========================================
# .template/installer.state.json is regenerated between every installer step,
# so prettier --check races against the writes. Skip the whole dir.
.template/

# ===========================================
# MCP browser snapshots - generated, gitignored
# ===========================================
# .playwright-mcp/page-*.yml are transient page snapshots emitted by the
# Playwright MCP server on every browser navigation. They are already gitignored
# but Prettier honors only .prettierignore (not .gitignore), so without this glob
# format:check fails on dozens of machine-generated .yml files.
.playwright-mcp/

# ===========================================
# Backup artifacts - generated, gitignored
# ===========================================
# .backups/ holds machine-generated backup dumps and key-mapping files (already
# gitignored). Prettier honors only .prettierignore (not .gitignore), so without
# this glob format:check would fail on those non-hand-authored files.
.backups/

# ===========================================
# Git worktrees - another branch's checkout, not this tree
# ===========================================
# A git worktree placed under .claude/worktrees/ is a separate branch's full
# checkout. Prettier (which honors only .prettierignore, not .git metadata)
# would otherwise recurse into it and flag formatting on files we don't own here.
.claude/worktrees/
